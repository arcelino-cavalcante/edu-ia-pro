rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        !exists(/databases/$(database)/documents/users/$(request.auth.uid)) ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Compatibilidade com o fluxo atual de alunos (sem Firebase Auth obrigatório).
    // Quando o login de aluno migrar para Firebase Auth, substitua por regras baseadas em isOwner/isSignedIn.
    function allowLegacyStudentClient() {
      return true;
    }

    match /users/{userId} {
      allow read: if isAdmin() || allowLegacyStudentClient();
      allow create: if isAdmin() || allowLegacyStudentClient();
      allow update, delete: if isAdmin() || allowLegacyStudentClient();

      match /progress/{progressDocId} {
        allow read, write: if isAdmin() || allowLegacyStudentClient();
      }

      match /notifications/{notificationId} {
        allow read, write: if isAdmin() || isOwner(userId) || allowLegacyStudentClient();
      }

      // Fallback path para convites em ambientes sem regra de root deployada.
      match /invite_links/{inviteId} {
        allow read: if true;
        allow write: if isAdmin();
      }

      match /{document=**} {
        allow read, write: if isAdmin() || allowLegacyStudentClient();
      }
    }

    // Estrutura normalizada (escalável)
    match /turmas/{document=**} { allow read: if true; allow write: if isAdmin(); }
    match /trails/{document=**} { allow read: if true; allow write: if isAdmin(); }
    match /courses/{document=**} { allow read: if true; allow write: if isAdmin(); }
    match /modules/{document=**} { allow read: if true; allow write: if isAdmin(); }
    match /lessons/{document=**} { allow read: if true; allow write: if isAdmin(); }

    // Estrutura legada (compat)
    match /structure/{document=**} { allow read: if true; allow write: if isAdmin(); }

    // Sistema de Configuração (Mega Catálogo CQRS e Seed)
    match /system_config/{document=**} { allow read: if true; allow write: if isAdmin(); }

    // Demais coleções de aplicação
    match /products/{document=**} { allow read: if true; allow write: if isAdmin(); }
    match /live_classes/{document=**} { allow read: if true; allow write: if isAdmin(); }
    match /invite_links/{document=**} { allow read: if true; allow write: if isAdmin(); }
    match /global_notifications/{document=**} { allow read: if true; allow write: if isAdmin(); }

    // Comunidade (aberto conforme comportamento atual da plataforma)
    match /comments/{document=**} { allow read, write: if true; }
    match /community_posts/{document=**} { allow read, write: if true; }

    // Telemetria de erros do frontend
    match /app_errors/{errorId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }
  }
}
